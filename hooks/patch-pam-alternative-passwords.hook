[Trigger]
Operation = Install
Operation = Upgrade
Type = File
Target = etc/pam.d/system-auth
Target = etc/xdg/quickshell/caelestia/assets/pam.d/passwd

[Action]
Description = Re-applying alternative password PAM configuration...
When = PostTransaction
Exec = /usr/local/bin/patch-pam-alternative-passwords.py
